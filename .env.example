# 환경변수 설정 가이드
# 이 파일을 복사하여 .env.local 로 저장하고 값을 채워넣으세요.

# ─── NextAuth ─────────────────────────────────────────────────
# 랜덤 시크릿 생성: openssl rand -base64 32
AUTH_SECRET=your-random-secret-here

# ─── Google OAuth ─────────────────────────────────────────────
# Google Cloud Console에서 발급: https://console.cloud.google.com
# OAuth 2.0 클라이언트 ID → 웹 애플리케이션
# 승인된 리디렉션 URI: http://localhost:3000/api/auth/callback/google
#                       https://your-project.vercel.app/api/auth/callback/google
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ─── Neon PostgreSQL (Vercel DB) ───────────────────────────────
# Vercel Dashboard → Storage → Create Database → Neon
# 또는 https://neon.tech 에서 직접 생성
DATABASE_URL=postgresql://username:password@host/database?sslmode=require

# ─── Gemini AI API Key ────────────────────────────────────────
# Google AI Studio: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIzaSy...

# ─── 앱 URL ──────────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
